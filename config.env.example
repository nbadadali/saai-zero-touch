# =============================================================================
# config.env  —  SINGLE SOURCE OF TRUTH for the deployment
# =============================================================================
# Copy this file to "config.env" and fill it in ONCE per client machine:
#     cp config.env.example config.env
#     nano config.env
#
# Everything the deployment needs lives here. Nothing host-specific or secret
# is hard-coded anywhere else. Leave a secret BLANK to have deploy.sh generate
# a strong random value for it automatically (only the safe-to-generate ones).
# =============================================================================

# ─── Identity ────────────────────────────────────────────────────────────────
# Linux user inside WSL2. Leave blank to auto-detect the current user.
LINUX_USER=""

# Name of the WSL2 distribution (as shown by `wsl -l -v` on Windows).
WSL_DISTRO="Ubuntu-22.04"

# ─── Application repository ──────────────────────────────────────────────────
REPO_URL="https://github.com/nbadadali/diplomatic-expression-docker.git"
# Where to clone it. $HOME is expanded at runtime.
REPO_DIR="$HOME/diplomatic-expression-docker"
# Pin to a specific git tag or commit for reproducible deploys (e.g. "v1.2.0").
# Leave blank to pull the latest main branch.
REPO_REVISION=""

# ─── WSL2 resource tuning (applied by windows-setup.ps1 on the host) ─────────
WSL_MEMORY_GB="6"
WSL_SWAP_GB="4"

# ─── Feature toggles ─────────────────────────────────────────────────────────
# OpenClaw install method:  npm | script | skip
#   npm    = npm install -g openclaw            (recommended, reproducible)
#   script = curl -fsSL https://openclaw.ai/install.sh | bash
#   skip   = OpenClaw already installed, do not touch it
OPENCLAW_INSTALL_METHOD="npm"
# Pin OpenClaw npm package version for reproducible deploys (e.g. "1.4.2").
# Leave blank to install the latest available version.
OPENCLAW_VERSION=""

# Gateway TCP port (loopback). Keep 18789 unless you have a conflict.
OPENCLAW_GATEWAY_PORT="18789"

# Standard SAAI deployments use the dedicated Windows Edge CDP profile created
# by: windows-setup.ps1 -EnableBrowser
ENABLE_BROWSER_AUTOMATION="true"
# Stable WSL hostname maintained by deploy.sh on every WSL boot.
WINDOWS_CDP_HOST="windows-host"
WINDOWS_CDP_PORT="9222"
OPENCLAW_BROWSER_PROFILE="windows-edge"

# ─── Stack secrets ───────────────────────────────────────────────────────────
# SAFE TO AUTO-GENERATE  (leave blank -> deploy.sh fills with strong random):
N8N_ENCRYPTION_KEY=""
N8N_JWT_SECRET=""
DB_POSTGRESDB_PASSWORD=""
PGVECTOR_PASSWORD=""
MCP_AUTH_TOKEN=""

# MUST be set by a human if you want remote access.
# For a purely local install you can leave these as the localhost defaults.
WEBHOOK_URL="http://localhost:5678"
N8N_EDITOR_BASE_URL="http://localhost:5678"

# Generated INSIDE n8n after first login (Settings -> API). Leave blank now;
# fill it in later and re-run:  ./deploy.sh --only env_file && (restart stack)
N8N_API_KEY=""

# ─── Stack runtime settings ───────────────────────────────────────────────────
# Tested n8n image. Upgrade only after validating migrations and workflows.
N8N_IMAGE_TAG="2.28.0"
# Maximum fresh-start migration/health wait.
N8N_STARTUP_TIMEOUT_SECONDS="600"

# Timezone passed through to n8n and workers.
# Use a valid tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
GENERIC_TIMEZONE="Asia/Dubai"

# Redis password — leave blank for no authentication (fine for local deployments).
# If set, the Redis container and n8n queue config are both updated automatically.
REDIS_PASSWORD=""
